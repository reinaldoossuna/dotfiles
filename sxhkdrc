#rofi -show run wm independent hotkeys
#


# make sxhkd reload its configuration files:
ctrl + shift + r
    pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit/restart bspwm
super + alt + {q,r}
    bspc {quit,wm -r}

# close/kill
ctrl + {_,shift + }q
    bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
    bspc desktop -l next

# send the newest marked node to the newest preselected node
alt + y
    bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest node
super + g
    bspc node -s biggest

#
# state/flags
#

# set the window "Mode" state Tiled/Pseudo_tiled/Floating/fullScreen
ctrl + shift + m; {t, p, f, s}
    bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags marked/locked/stick/private
super + shift + {m,x,y,z,h}
    bspc node -g {marked,locked,sticky,private,hidden}

super + alt + h
    bspc node any.hidden --flag hidden=off

#
# focus/swap
#

# focus the node in the given direction west/south/north/east
super + {_,shift + }{k, n, e, i}
    bspc node -{f,s} {west,south,north,east}

# move a floating window
super + {_, shift +}{Left,Down,Up,Right}
    bspc node -{f,s} {west,south,north,east}

# focus the node in the given direction west/south/north/east
super + {_,shift + }{k, n, e, i}
    bspc node -{f,s} {west,south,north,east}

# focus the node for the given path jump parent/brother/first/second
super + {p,b,comma,period}
    bspc node -f @{parent,brother,first,second}

# cycle windows next/prev
super + {_,shift + }Tab
    bspc node -f {next,prev}

# focus the next/previous node in the current desktop
super + {_,shift + }n
    bspc node -f {next,prev}.local

# bring all hidden nodes
super + alt + h
    bspc node any.hidden --flag hidden=off

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
    bspc desktop -f {prev,next}.local

# focus the last node/desktop
alt + {grave,Tab}
    bspc {node,desktop} -f last

ctrl + Tab
    bspc monitor -f last

# focus the older/newer node in the focus history
super + {y,u}
    bspc wm -h off; \
    bspc node {older,newer} -f; \
    bspc wm -h on

# focus/send to the given desktop
ctrl + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} '^{1-9,10}'

super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} '^{1-9,10}'

# Rotate children
super + o
	bspc node '@parent.vertical' -y horizontal \
	    || bspc node '@parent' -y vertical

#
# preselect
#

# preselect the direction west/south/north/east
super + alt + {k, n, e, i}
    bspc node -p {west,south,north,east}

super + alt + {left, down, up, right}
    bspc node -p {west,south,north,east}

super + alt + {1-9}
    bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + alt + space
    bspc node -p cancel

# cancel the preselection for the focused desktop
super + alt + shift + space
    bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# expand a window by moving one of its side outward left/bottom/up/right
alt + {k, n, e, i}
    bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward left/bottom/top/right
alt + shift + {k, n, e, i}
    bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# change window gap at run time
super + plus
    bspc config -d focused window_gap $((`bspc config -d focused window_gap` + 10 ))

# Restore original gap
super + equal
    bspc config -d focused window_gap 4

super + minus
    bspc config -d focused window_gap $((`bspc config -d focused window_gap` - 10 ))

# Move current window to largest space or preselected area if there is one.
ctrl + shift + @space
    windowpromoter


#
# spawn programs
#

# terminal emulator
super + @space
    default-terminal

# program launcher
super + shift +  space
    ~/.config/rofi/launchers-ribbon/launcher-dm.sh

# super + shift + space
#     ~/.config/eww/launcher

XF86Audio{Prev,Next}
  playerctl -p spotifyd  {previous,next}

XF86AudioPlay + {_, shift}
  playerctl -p spotifyd  {play, pause}

XF86Audio{RaiseVolume,LowerVolume,Mute}
  pulseaudio-ctl {up,down,mute}

super + Pause + {_, alt}
  {reboot, poweroff}

Pause
  ~/Documents/scripts/lock.sh

Print
  NAME="$HOME/Pictures/$(date +%s).png" ; maim -s $NAME ; echo -n $NAME | xclip -sel clip ;  notify-send "$NAME"

super + w
    firefox

super + f
    default-terminal -e nnn

super + shift + f
  dolphin

ctrl + shift + o; {f, n, w, z, s, t, e, c}
  {dolphin, \
  default-terminal -e nnn, \
  firefox, \
  zathura, \
  spotify,\
  default-terminal, \
  emacsclient -c, \
  default-terminal -e pulsemixer}
