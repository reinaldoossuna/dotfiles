include-file = ~/.config/polybar/colors
include-file = ~/.config/polybar/module-slim

[bar/main]
monitor = VIRTUAL1
##monitor = HDMI-1-3
bottom = false
width = 100%
height = 4
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
border-size = 0
border-color = ${colors.background}
line-size = 7
module-margin = 2
modules-left = bspwm
modules-right = pulseaudio wlan eth battery powermenu
font-0 = Hack:pixelsize=10
padding = 0
cursor-click = pointer
cursor-scroll = ns-resize
wm-restack = bspwm
override-redirect = false
underline-color = ${colors.background}
overline-color = ${colors.background}

[bar/side]
inherit = bar/main
monitor = eDP1
height = 5
modules-left = bspwm-side
modules-right =
font-0 = Hack:pixelsize=10
